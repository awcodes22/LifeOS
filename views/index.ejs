<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LifeOS – Dashboard</title>
  <link rel="icon" type="image/svg+xml" href="/images/LifeOS small logo.svg">
  <link rel="stylesheet" href="/styles/styles.css">
  <link rel="stylesheet" href="/styles/dashboard.css">
  <!-- Font Awesome for icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw=="
    crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>

<body>


  <!-- ambient blobs -->
  <div class="los-blob los-blob--1"></div>
  <div class="los-blob los-blob--2"></div>
  <div class="los-blob los-blob--3"></div>

  <!-- Navbar -->
  <nav class="los-nav">
    <a href="/" class="los-nav__logo">
      <img src="/images/LifeOS logo.svg" alt="LifeOS">
    </a>
    <ul class="los-nav__links">
      <li><a href="/" class="active">Dashboard</a></li>
      <li><a href="/journal">Journal</a></li>
      <li><a href="/tasks">Tasks</a></li>
      <li><a href="/insights">Insights</a></li>
    </ul>
    <button class="los-nav__logout" onclick="document.getElementById('logoutModal').classList.add('active')">
      <i class="fa-solid fa-arrow-right-from-bracket"></i> Logout
    </button>
    <button class="los-nav__hamburger" id="hamburger" onclick="toggleMenu()" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </nav>
  <div class="los-nav__mobile" id="mobileMenu" onclick="handleOverlayClick(event)">
    <button class="los-nav__mobile-close" onclick="toggleMenu()" aria-label="Close menu">
      <i class="fa-solid fa-xmark"></i>
    </button>
    <a href="/" class="active">Dashboard</a>
    <a href="/journal">Journal</a>
    <a href="/tasks">Tasks</a>
    <a href="/insights">Insights</a>
    <button class="los-nav__mobile-logout" onclick="toggleMenu(); document.getElementById('logoutModal').classList.add('active')">
      <i class="fa-solid fa-arrow-right-from-bracket"></i> Logout
    </button>
  </div>

  <!-- Hero -->
  <section class="los-hero">

    <div class="los-hero__inner">

      <div class="los-hero__avatar los-hero__avatar--initials anim anim-d1">
        <%= user.name.charAt(0).toUpperCase() %>
      </div>

      <h1 class="los-hero__greeting anim anim-d2"><%= greeting %>, <%= user.name.split(' ')[0] %></h1>
      <p class="los-hero__date anim anim-d3" id="js-date"></p>

      <div class="los-hero__quote anim anim-d4">
        <p id="js-quote">We are what we repeatedly do. Excellence, then, is not an act, but a habit.</p>
        <cite id="js-quote-author">— Aristotle</cite>
      </div>

      <div class="los-hero__actions anim anim-d5">
        <button class="btn-los-primary" onclick="openReflectionModal()">
          <i class="fa-solid fa-pen-to-square"></i> New Reflection
        </button>
        <a href="/focusMode" class="btn-los-ghost">
          <i class="fa-solid fa-bullseye"></i> Enter Focus Mode
        </a>
      </div>

    </div>

  </section>

  <!-- Main -->
  <main class="los-main">

    <!-- Overview Stats -->
    <div class="los-section-header anim anim-d6">
      <h2 class="los-section-title">Overview</h2>
    </div>

    <div class="los-stats">

      <!-- Total Logs -->
      <a href="/journal" class="los-stat-card anim anim-d7">
        <div class="los-stat-icon los-stat-icon--blue">
          <i class="fa-solid fa-book-open"></i>
        </div>
        <div class="los-stat-body">
          <p class="los-stat-label">Reflections</p>
          <p class="los-stat-value" id="js-logs-total">0</p>
          <p class="los-stat-sub">Reflections written</p>
        </div>
      </a>

      <!-- Tasks -->
      <a href="/tasks" class="los-stat-card anim anim-d7">
        <div class="los-stat-icon los-stat-icon--teal">
          <i class="fa-solid fa-circle-check"></i>
        </div>
        <div class="los-stat-body">
          <p class="los-stat-label">Tasks Completed</p>
          <p class="los-stat-value" id="js-tasks-done">0</p>
          <p class="los-stat-sub"><span id="js-tasks-rate">0</span>% completion rate</p>
        </div>
      </a>

      <!-- Focus Sessions -->
      <a href="/focusMode" class="los-stat-card anim anim-d7">
        <div class="los-stat-icon los-stat-icon--indigo">
          <i class="fa-solid fa-clock"></i>
        </div>
        <div class="los-stat-body">
          <p class="los-stat-label">Focus Sessions</p>
          <p class="los-stat-value" id="js-focus-total">0</p>
          <p class="los-stat-sub">Sessions completed</p>
        </div>
      </a>

    </div>

    <!-- Footer -->
    <footer class="los-footer">
      &copy; <span id="js-year"></span> LifeOS. All rights reserved.
    </footer>

  </main>

  <!-- New Reflection Modal -->
  <div class="modal-overlay" id="reflectionModal" onclick="closeReflectionModal(event)">
    <div class="modal" onclick="event.stopPropagation()">
      <div class="modal__header">
        <h2 class="modal__header-title">Today's Reflection</h2>
        <p class="modal__header-date" id="reflModalDate"></p>
      </div>
      <form onsubmit="saveReflection(event)">
        <label class="modal__label" for="reflTitle">Title</label>
        <input class="modal__input modal__input--title" id="reflTitle" name="title" type="text"
          placeholder="Journal title" required>

        <label class="modal__label" for="reflContent">How was your day?</label>
        <textarea class="modal__input" id="reflContent" name="content" rows="4"
          placeholder="What's on your mind today?" required></textarea>

        <label class="modal__label">How are you feeling?</label>
        <div class="modal-mood">
          <div class="modal-mood__option mood--terrible" data-mood="Terrible" onclick="selectReflMood(this)">
            <span class="modal-mood__emoji">😡</span><span class="modal-mood__label">Terrible</span>
          </div>
          <div class="modal-mood__option mood--bad" data-mood="Bad" onclick="selectReflMood(this)">
            <span class="modal-mood__emoji">☹️</span><span class="modal-mood__label">Bad</span>
          </div>
          <div class="modal-mood__option mood--okay" data-mood="Okay" onclick="selectReflMood(this)">
            <span class="modal-mood__emoji">😐</span><span class="modal-mood__label">Okay</span>
          </div>
          <div class="modal-mood__option mood--good" data-mood="Good" onclick="selectReflMood(this)">
            <span class="modal-mood__emoji">😊</span><span class="modal-mood__label">Good</span>
          </div>
          <div class="modal-mood__option mood--excellent" data-mood="Excellent" onclick="selectReflMood(this)">
            <span class="modal-mood__emoji">😄</span><span class="modal-mood__label">Excellent</span>
          </div>
        </div>
        <input type="hidden" id="reflMood" name="mood" value="">

        <div class="modal__actions">
          <button type="button" class="btn-los-ghost" onclick="closeReflectionModal()">Cancel</button>
          <button type="submit" class="btn-los-primary"><i class="fa-solid fa-floppy-disk"></i> Save</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Delete confirmation modal -->
  <div class="del-overlay" id="deleteModal">
    <div class="del-card">
      <div class="del-card__icon">
        <i class="fa-solid fa-trash"></i>
      </div>
      <h2 class="del-card__title">Delete Entry?</h2>
      <p class="del-card__sub">This can't be undone.</p>
      <div class="del-card__actions">
        <button class="btn-los-ghost" onclick="hideDeleteModal()">
          <i class="fa-solid fa-xmark"></i> Cancel
        </button>
        <button class="btn-danger" onclick="confirmDelete()">
          <i class="fa-solid fa-trash"></i> Delete
        </button>
      </div>
    </div>
  </div>

  <script src="/js/dashboard.js"></script>

  <!-- Logout Confirmation Modal -->
  <div class="del-overlay" id="logoutModal" onclick="if(event.target===this)this.classList.remove('active')">
    <div class="del-card">
      <div class="del-card__icon">
        <i class="fa-solid fa-arrow-right-from-bracket"></i>
      </div>
      <p class="del-card__title">Log out?</p>
      <p class="del-card__sub">You'll need to sign back in to access your data.</p>
      <div class="del-card__actions">
        <button class="btn-los-ghost" onclick="document.getElementById('logoutModal').classList.remove('active')">Cancel</button>
        <a href="/auth/logout" class="btn-danger">Log out</a>
      </div>
    </div>
  </div>

</body>
</html>
